# Demo mode (vite --mode demo) — safe to commit, contains no secrets.
# All /api calls are intercepted in the browser (src/demo) — no backend used.
VITE_DEMO_MODE=true
# Empty base keeps endpoints relative (/api/...) so the interceptor owns them.
VITE_API_BASE_URL=
# Where the demo ribbon's "Get Lumen free" CTA points (lumen site dev port).
VITE_MARKETING_URL=http://localhost:5175
