# Copy to .env and adjust for your network.
# Vite only exposes variables prefixed with VITE_

# Production (Contabo + Cloudflare)
# VITE_API_BASE_URL=https://ruirufactorymabati.com
# VITE_RADIUS_SERVER=YOUR_CONTABO_PUBLIC_IP

# Local development
VITE_API_BASE_URL=http://localhost:5000
VITE_RADIUS_SERVER=YOUR_SERVER_IP
