# Copy to `.env` and set your Infora backend URL to run against the live API.
# Leave unset (or delete .env) to run in DEMO mode with seeded mock data.
#
# LAN dev (phone + laptop on same wifi — use the laptop's IP, not localhost):
#   EXPO_PUBLIC_API_URL=http://192.168.1.10:5000
# Android emulator reaching a backend on the host machine:
#   EXPO_PUBLIC_API_URL=http://10.0.2.2:5000
# Production:
#   EXPO_PUBLIC_API_URL=https://api.infora.app

EXPO_PUBLIC_API_URL=
