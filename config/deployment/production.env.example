# =============================================================================
# Production — Contabo VPS + Cloudflare (ruirufactorymabati.com)
# On the VPS:
#   mkdir -p /srv/infora-billing && cd /srv/infora-billing
#   cp config/deployment/production.env.example .env
# Full guide: config/deployment/CONTABO.md
# =============================================================================

# --- Contabo public IPv4 (MikroTik RADIUS + WireGuard must reach this IP) ---
# Find in Contabo panel → Your VPS → IP addresses
CONTABO_PUBLIC_IP=YOUR_CONTABO_IPV4

# --- Domain (Cloudflare proxied for HTTPS web UI) ---
APP_DOMAIN=ruirufactorymabati.com
VITE_API_BASE_URL=https://ruirufactorymabati.com
CORS_ORIGINS=https://ruirufactorymabati.com,https://www.ruirufactorymabati.com,https://billing.ruirufactorymabati.com

# MikroTik RADIUS + WireGuard use IP or DNS-only hostname (NOT Cloudflare orange-cloud)
PUBLIC_SERVER_HOST=YOUR_CONTABO_IPV4
FREERADIUS_HOST=YOUR_CONTABO_IPV4
WIREGUARD_MGMT_ENDPOINT=wg.ruirufactorymabati.com
WIREGUARD_MGMT_PORT=51821

# --- Secrets (generate: openssl rand -hex 32) ---
SECRET_KEY=CHANGE_ME_openssl_rand_hex_32
JWT_SECRET_KEY=CHANGE_ME_jwt_secret
ENCRYPTION_KEY=CHANGE_ME_fernet_or_same_as_secret
RADIUS_SECRET=CHANGE_ME_radius_shared_secret
POSTGRES_PASSWORD=CHANGE_ME_db_password

DATABASE_URL=postgresql://infora_user:CHANGE_ME_db_password@postgres:5432/infora_billing
FLASK_ENV=production

# --- WireGuard customer VPN + MikroTik auto-push ---
WIREGUARD_CONFIG_DIR=/app/wireguard_configs
WIREGUARD_MIKROTIK_AUTO_PUSH=true

# --- Frontend build args (used by config/nginx/Dockerfile) ---
VITE_RADIUS_SERVER=YOUR_CONTABO_IPV4

# --- M-Pesa (production callback must use HTTPS domain) ---
MPESA_ENVIRONMENT=production
MPESA_CALLBACK_URL=https://ruirufactorymabati.com/api/payments/mpesa/callback
# MPESA_CONSUMER_KEY=
# MPESA_CONSUMER_SECRET=
# MPESA_SHORTCODE=
# MPESA_PASSKEY=
